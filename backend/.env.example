DATABASE_URL=sqlite:///./bistate.db
UPLOAD_DIR=./uploads
# Live providers are opt-in. Missing credentials return explicit unavailable data.
LIVE_PROVIDERS_ENABLED=false
FEMA_API_URL=
CENSUS_API_KEY=
ASSESSOR_API_KEY=
PARCEL_API_KEY=
SCHOOLS_API_KEY=
ZONING_API_KEY=
STR_REGULATIONS_API_KEY=
ROUTING_API_KEY=
PLACES_API_KEY=
WALKSCORE_API_KEY=
AIRDNA_API_KEY=
PROVIDER_TIMEOUT_SECONDS=8
PROVIDER_RETRY_COUNT=2
# Cache successful live routing and places lookups to reduce quota use.
PROVIDER_CACHE_SECONDS=3600
# ROUTING_API_KEY must be a Google Maps Platform key with the Directions API enabled.
# PLACES_API_KEY must be a Google Maps Platform key with the Places API enabled.
